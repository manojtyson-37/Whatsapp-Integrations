{
  "services": {
    "frontend": {
      "root": "frontend",
      "framework": "vite"
    },
    "api": {
      "root": "api",
      "entrypoint": "index.js"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)?",
      "destination": {
        "type": "service",
        "service": "api"
      }
    },
    {
      "source": "/(.*)",
      "destination": {
        "type": "service",
        "service": "frontend"
      }
    }
  ]
}
